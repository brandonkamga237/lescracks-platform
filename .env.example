# =============================================================================
# LesCracks Platform — Variables d'environnement production
# =============================================================================
# Copier ce fichier en .env sur le serveur : /root/lescracks/.env
# NE PAS commiter le fichier .env
# =============================================================================

# ── Base de données ────────────────────────────────────────────────────────────
DB_HOST=lescracks-postgres
DB_PORT=5432
DB_NAME=lescracks
DB_USERNAME=lescracks
DB_PASSWORD=CHANGE_ME_strong_password

# ── Spring JPA ────────────────────────────────────────────────────────────────
# "update" pour le premier déploiement (crée les tables automatiquement)
# Changer en "validate" après le premier déploiement réussi
SPRING_DDL_AUTO=update

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_minimum_256_bits_random_string_here_xxxxxxxxxxxxxxxxxxxxx
JWT_EXPIRATION=86400000

# ── URLs ──────────────────────────────────────────────────────────────────────
APP_URL=https://lescracks.com
FRONTEND_URL=https://lescracks.com
CORS_ORIGINS=https://lescracks.com,https://www.lescracks.com

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_HOST=lescracks-minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=CHANGE_ME_minio_user
MINIO_SECRET_KEY=CHANGE_ME_minio_password
MINIO_BUCKET=lescracks
MINIO_ENDPOINT=http://lescracks-minio:9000
MINIO_PUBLIC_URL=https://minio.lescracks.com

# ── OAuth2 ────────────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=CHANGE_ME
GITHUB_CLIENT_SECRET=CHANGE_ME
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME

# ── Uploads ───────────────────────────────────────────────────────────────────
UPLOADS_DIR=/app/uploads

# ── Serveur ───────────────────────────────────────────────────────────────────
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=prod
