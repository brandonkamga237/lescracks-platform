# Spring Profile (dev, test, prod)
SPRING_PROFILES_ACTIVE=prod

# Application
SERVER_PORT=8080
FRONTEND_URL=https://your-production-domain.com
APP_URL=https://your-production-domain.com
CORS_ORIGINS=https://your-production-domain.com

# Database Configuration (Production)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=lescracks
DB_USERNAME=lescracks
DB_PASSWORD=change-this-to-a-secure-password

# JWT Configuration (Production - use a strong secret!)
# Generate with: openssl rand -hex 48
JWT_SECRET=generate-a-strong-secret-with-openssl-rand-hex-48
JWT_EXPIRATION=86400000

# Email / SMTP (SpaceMail — Spaceship)
# Outgoing server mail.spacemail.com, port 587 (STARTTLS) or 465 (implicit SSL)
MAIL_HOST=mail.spacemail.com
MAIL_PORT=587
MAIL_USERNAME=contact@lescracks.com
MAIL_PASSWORD=your-mailbox-password
MAIL_FROM=LesCracks <contact@lescracks.com>
MAIL_ADMIN=contact@lescracks.com

# GitHub OAuth2 (Production)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Google OAuth2 (Production)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# MinIO Configuration (Production)
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_BUCKET=lescracks
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_URL=https://your-minio-public-url
